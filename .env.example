# Base URL of the AIQ backend API (includes the /api/v1 prefix).
#
# Vite loads env files by mode, so you normally don't edit this file directly:
#   .env.development  → used by `npm run dev`   (local backend)
#   .env.production   → used by `npm run build` (deployed backend)
# For a personal, git-ignored override, create `.env.local`.
VITE_API_URL=https://backend-h5v6.onrender.com/api/v1
